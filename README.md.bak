━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
          📌 𝐀𝐋𝐏𝐇𝐀 𝐗 𝐁𝐎𝐓
        📄 شرح ملف main.js
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🇸🇦 أولاً: فكرة البوت
هذا الملف هو "القلب الرئيسي" للبوت،
وهو المسؤول عن تشغيل كل شيء داخل النظام:
- تشغيل الأوامر
- إدارة الرسائل
- تحميل الملفات
- تشغيل الأنظمة التلقائية
- إدارة قاعدة البيانات

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🔧 1) تحميل المكتبات
يستخدم البوت مكتبات مثل:
- pino → تسجيل الأحداث (logs)
- chalk → تلوين الكونسول
- moment-timezone → الوقت
- fs / path → إدارة الملفات
- chokidar → مراقبة التعديلات

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

📦 2) نظام الأوامر (Commands)
كل الأوامر داخل مجلد:
/commands

يتم تحميلها تلقائياً في الذاكرة:
- اسم الأمر
- الاختصارات (aliases)

مثال:
.help
!help
#help
كلها نفس الأمر

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🔁 3) Hot Reload
أي تعديل في:
- commands
- lib

يتم تحديثه مباشرة بدون إعادة تشغيل البوت

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🧠 4) Middleware (قبل التنفيذ)
يقوم بـ:
- فلترة الرسائل
- التأكد أنها ليست نظامية
- تحديد إذا كانت أمر
- تسجيل في الكونسول (logs)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

⚙️ 5) Handler الرئيسي
يستقبل كل رسائل واتساب ويحدد:
- رسالة عادية
- رسالة نظام
- تحديث مجموعة

ثم يوجهها للنظام المناسب

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🧾 6) قاعدة البيانات (Database)

👤 المستخدم:
- exp
- level
- coins
- bank
- warnings
- premium
- banned

👥 الجروب:
- welcome
- anti-link
- anti-spam
- anti-fake

🌐 إعدادات البوت:
- botName
- mode (public/private)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🛡️ 7) الأنظمة التلقائية (Systems)
/lib

كل ملف داخل lib يعمل كنظام مستقل مثل:
- الحماية
- المراقبة
- الأتمتة

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🎯 8) تنفيذ الأوامر
إذا الرسالة تبدأ بـ:
. ! # /

يتم:
1. استخراج الأمر
2. البحث عنه
3. تشغيله
4. تنفيذ الكود
5. تحديث بيانات المستخدم

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

📁 هيكل المشروع:

alpha/
│
├── commands/  → الأوامر
├── lib/       → الأنظمة
├── src/       → ملفات أساسية
├── config.js  → الإعدادات
├── index.js   → تشغيل البوت
├── main.js    → القلب الرئيسي
├── package.json

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

🇬🇧 ENGLISH SUMMARY

This is the core system of ALPHA X bot:

- Loads commands dynamically
- Handles WhatsApp messages
- Runs middleware before execution
- Supports hot reload (no restart needed)
- Manages database for users & groups
- Runs automation systems from /lib
- Executes commands based on prefixes (. ! # /)

